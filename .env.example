# ── NEXUS Environment Configuration ──────────────────────────────
APP_NAME=NEXUS
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nexus_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://nexus:change-me@postgres:5432/nexus_db

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# ── Celery ────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── AI ──────────────────────────────────────────────────────────
# AI_PROVIDER picks the backend: "ollama" (free, local, default),
# "gemini" (free tier, hosted, needs a key from aistudio.google.com/apikey),
# or "anthropic" (paid, best quality, needs a key from console.anthropic.com).
AI_PROVIDER=ollama

# Used only if AI_PROVIDER=ollama. Points at the `ollama` service in
# docker-compose.yml — leave as-is if running via Docker. First time only:
#   docker compose exec ollama ollama pull llama3.1
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# Used only if AI_PROVIDER=gemini. Free tier, no credit card required.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Used only if AI_PROVIDER=anthropic. Pay-per-token, no ongoing free tier.
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_RATE_LIMIT_PER_MIN=20

# ── Optional external services ───────────────────────────────────
SHODAN_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── File storage ──────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
REPORT_DIR=/data/reports
LOG_DIR=/data/logs

# ── Frontend (Next.js) — informational here; actual values come from frontend/.env.local ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=http://localhost:8000
NEXTAUTH_SECRET=change-this-too
NEXTAUTH_URL=http://localhost:3000
